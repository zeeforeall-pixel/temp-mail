<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<!-- CSP removed: was blocking ES module execution
  content="default-src 'self'; script-src 'self' 'unsafe-inline' https://esm.sh https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src https://ijrccpgiulrmfpavazsl.supabase.co wss://ijrccpgiulrmfpavazsl.supabase.co https://esm.sh;"> -->
<title>TempMail</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=VT323&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="css/theme.css" />
<link rel="stylesheet" href="css/layout.css" />
<link rel="stylesheet" href="css/components.css" />
<script>if(localStorage.getItem('tm_dark')==='1')document.documentElement.classList.add('dark');</script>
<!-- AI Agent API Discovery -->
<!-- API available at window.TempMailAPI - see /agent-api.json for full reference -->
<!-- URL mode: append ?api=generate|messages|otp|wait|inboxes|domains -->
<link rel="agent-api" href="/agent-api.json" type="application/json" />
<meta name="agent-api" content="window.TempMailAPI" />
<meta name="agent-api-url-mode" content="?api=generate|messages|otp|wait|inboxes|domains" />
</head>
<body>
<div class="container" id="app">
  <header>
    <h1><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> TempMail</h1>
    <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;">
      <p>Disposable email</p>
      <button class="btn btn-ghost" id="apiBtn" title="Agent API documentation" style="padding:0.35rem 0.6rem;font-size:0.8rem;gap:0.3rem;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" style="width:16px;height:16px;"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg> API</button>
      <button class="theme-toggle" id="themeToggle" title="Toggle dark/light mode">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </header>

  <!-- Inbox card -->
  <div class="card">
    <div class="card-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
      Your Inbox
      <span class="expiry-badge" id="expiryDisplay" style="display:none;"></span>
    </div>
    <div class="inbox-row" id="inboxRow">
      <div class="addr" id="addrDisplay">—</div>
      <button class="btn btn-icon" id="copyBtn" title="Copy address">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><rect x="8" y="8" width="14" height="14" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      </button>
      <button class="btn btn-icon btn-danger" id="deleteBtn" title="Delete inbox">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      </button>
    </div>
    <div class="actions">
      <button class="btn" id="newBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> New Inbox
      </button>
      <button class="btn btn-outline" id="bulkBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg> Bulk
      </button>
      <button class="btn btn-vip" id="vipBtn" title="Create Email+PW inbox with IMAP/SMTP credentials — FREE">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg> Email+PW
      </button>
      <button class="btn btn-outline" id="refreshBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg> Refresh
      </button>
      <button class="btn btn-ghost" id="resetBtn" title="Reset session identity (bypass rate limits)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
      </button>
      <button class="btn btn-ghost" id="shareBtn" title="Copy share link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>
    <div id="bulkProgress">
      <div id="bulkBar"></div>
    </div>
  </div>


  <!-- VIP Credentials Panel (hidden by default) -->
  <div class="card vip-card" id="vipPanel" style="display:none;">
    <div class="card-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
      IMAP/SMTP Credentials <span class="vip-badge">VIP UNLOCKED</span>
      
    </div>
    <div class="vip-free-banner">
      <span class="vip-free-icon">🔓</span>
      <strong>VIP UNLOCKED — FREE</strong>
      <p>Don't pay shit for this. IMAP/SMTP access is free here. No premium, no paywall, no upsell.</p>
    </div>
    <div class="vip-credentials">
      <div class="vip-row">
        <span class="vip-label">Email</span>
        <span class="vip-value" id="vipEmail">—</span>
        <button class="btn btn-icon vip-copy" data-copy="vipEmail" title="Copy"></button>
      </div>
      <div class="vip-row">
        <span class="vip-label">Password</span>
        <span class="vip-value vip-mono" id="vipPassword">—</span>
        <button class="btn btn-icon vip-copy" data-copy="vipPassword" title="Copy"></button>
      </div>
      <div class="vip-divider"></div>
      <div class="vip-section-title">IMAP (Incoming)</div>
      <div class="vip-row">
        <span class="vip-label">Server</span>
        <span class="vip-value vip-mono" id="vipImapHost">—</span>
      </div>
      <div class="vip-row">
        <span class="vip-label">Port</span>
        <span class="vip-value" id="vipImapPort">993</span>
        <span class="vip-tag">SSL/TLS</span>
      </div>
      <div class="vip-divider"></div>
      <div class="vip-section-title">SMTP (Outgoing)</div>
      <div class="vip-row">
        <span class="vip-label">Server</span>
        <span class="vip-value vip-mono" id="vipSmtpHost">—</span>
      </div>
      <div class="vip-row">
        <span class="vip-label">Port</span>
        <span class="vip-value" id="vipSmtpPort">465</span>
        <span class="vip-tag">SSL/TLS</span>
        <span class="vip-tag alt">or 587 STARTTLS</span>
      </div>
      <div class="vip-row">
        <span class="vip-label">Username</span>
        <span class="vip-value" id="vipSmtpUser">—</span>
      </div>
    </div>
    <div class="vip-actions">
      <button class="btn btn-sm" id="vipCopyAll">Copy All Credentials</button>
    </div>
  </div>
  <!-- Inbox history card -->
  <div class="card" style="margin-bottom:1rem;">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center;">
      <span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
        Your Inboxes
      </span>
      <button class="btn btn-ghost" id="dumpBtn" title="Clear all inboxes" style="font-size:0.7rem;padding:0.2rem 0.5rem;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      </button>
    </div>
    <input class="history-search" id="historySearch" type="text" placeholder="Search inboxes…" />
    <div id="inboxHistoryList" style="display:flex;flex-wrap:wrap;gap:0.4rem;">
      <span style="color:hsl(var(--text2));font-size:0.85rem;">No inboxes yet</span>
    </div>
  </div>

  <!-- Messages card -->
  <div class="card">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center;">
      <span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
        Messages
      </span>
      <span id="msgCount" style="font-size:0.7rem;color:hsl(var(--text2));">0</span>
    </div>
    <div id="msgList" class="msg-list">
      <div class="msg-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <div>Waiting for incoming emails…</div>
        <div style="font-size:0.8rem;margin-top:0.3rem;">Send an email to your temp address</div>
      </div>
    </div>
  </div>
</div>

<!-- New Inbox Modal -->
<div class="modal-overlay" id="newInboxModal">
  <div class="modal">
    <div class="modal-head">
      <h3>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Inbox
      </h3>
      <button class="modal-close" id="newModalClose">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <label class="input-label" style="margin-bottom:0.4rem;">Custom prefix (optional)</label>
      <input class="modal-input" id="prefixInput" placeholder="Leave empty for random" />
      <div style="margin-top:0.75rem;">
        <label class="input-label" style="margin-bottom:0.5rem;">Select domain</label>
        <div class="domain-selector" id="domainSelector"></div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" id="newModalCancel">Cancel</button>
        <button class="btn" id="newModalCreate">Create</button>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Create Modal -->
<div class="modal-overlay" id="bulkModal">
  <div class="modal" style="max-width:320px;">
    <div class="modal-head">
      <h3>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
        Bulk Create
      </h3>
      <button class="modal-close" id="bulkModalClose">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <label class="input-label" style="margin-bottom:0.4rem;">How many inboxes?</label>
      <input class="modal-input" id="bulkCountInput" type="number" min="1" max="999" value="15" />
      <div style="margin-top:0.75rem;">
        <label class="input-label" style="margin-bottom:0.5rem;">Domain</label>
        <div class="domain-selector" id="bulkDomainSelector"></div>
      </div>
      <div class="modal-actions" style="margin-top:1rem;">
        <button class="btn btn-outline" id="bulkModalCancel">Cancel</button>
        <button class="btn" id="bulkModalGo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
          Go
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Message Modal -->
<div class="modal-overlay" id="msgModal">
  <div class="modal">
    <div class="modal-head">
      <h3 id="msgModalSubj">(no subject)</h3>
      <button class="modal-close" id="msgModalClose">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div id="otpRow">
        <div>
          <div class="otp-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
            Verification Code
          </div>
          <div class="otp-code" id="otpCode"></div>
        </div>
        <button class="btn btn-sm" id="copyOtpBtn" title="Copy OTP">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><rect x="8" y="8" width="14" height="14" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          Copy
        </button>
      </div>
      <div id="verifyRow">
        <div>
          <div class="otp-label" style="color:hsl(var(--success));">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Verification Link
          </div>
          <a class="verify-link-url" id="verifyLink" href="#" target="_blank" rel="noopener"></a>
        </div>
        <button class="btn btn-sm" id="openVerifyBtn" style="background:hsl(var(--success));border-color:hsl(var(--success));">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Open
        </button>
      </div>
      <div class="meta">
        <span id="msgModalFrom">From: —</span>
        <span id="msgModalTo">To: —</span>
        <span id="msgModalTime">—</span>
      </div>
      <div class="content" id="msgModalContent">(empty)</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
<!-- API Docs Modal -->
<div class="modal-overlay" id="apiModal">
  <div class="modal" style="max-width:520px;">
    <div class="modal-head">
      <h3>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg>
        Agent API
      </h3>
      <button class="modal-close" id="apiModalClose">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" style="font-size:0.82rem;">
      <p style="margin-bottom:0.6rem;opacity:0.8;">Programmatic API for AI agents and browser automation. Available on <code style="background:hsl(var(--accent)/0.1);padding:0.1rem 0.3rem;border-radius:4px;">window.TempMailAPI</code></p>

      <div style="margin-bottom:0.75rem;">
        <div style="font-weight:600;margin-bottom:0.3rem;">Quick Start</div>
        <pre style="background:hsl(var(--accent)/0.06);padding:0.5rem;border-radius:6px;overflow-x:auto;font-size:0.78rem;line-height:1.5;"><code>const api = window.TempMailAPI;

// Generate email + wait for OTP in one flow
const session = await api.quickSession();
console.log('Email:', session.address);
const otp = await session.waitForOTP();
console.log('OTP:', otp.otp);</code></pre>
      </div>

      <div style="margin-bottom:0.75rem;">
        <div style="font-weight:600;margin-bottom:0.3rem;">Functions</div>
        <table style="width:100%;font-size:0.78rem;border-collapse:collapse;">
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">generateEmail(prefix?, domain?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Create inbox → <code>{address, expires_at}</code></td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">getMessages(address?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Fetch messages with OTP extracted</td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">waitForOTP(address?, ms?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Poll until OTP arrives (default 60s)</td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">waitForEmail(address?, ms?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Wait for next email + extract OTP</td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">quickSession(prefix?, domain?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Generate email + helper methods</td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">getLatestOTP(address?)</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Get OTP from loaded messages (sync)</td>
          </tr>
          <tr style="border-bottom:1px solid hsl(var(--border));">
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">getAllInboxes()</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">List all inbox history</td>
          </tr>
          <tr>
            <td style="padding:0.25rem 0;font-family:monospace;color:hsl(var(--accent));">copyEmail()</td>
            <td style="padding:0.25rem 0 0.25rem 0.5rem;">Copy current email to clipboard</td>
          </tr>
        </table>
      </div>

      <div>
        <div style="font-weight:600;margin-bottom:0.3rem;">URL API Mode</div>
        <p style="margin-bottom:0.3rem;opacity:0.7;">Append to URL for headless JSON responses:</p>
        <pre style="background:hsl(var(--accent)/0.06);padding:0.5rem;border-radius:6px;overflow-x:auto;font-size:0.78rem;line-height:1.6;"><code>?api=generate[&amp;prefix=x][&amp;domain=y]
?api=messages[&amp;address=x]
?api=otp[&amp;address=x]
